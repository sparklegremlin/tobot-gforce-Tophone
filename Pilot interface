<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TOBOT G-FORCE // PILOT INTERFACE</title>
<style>
  :root{
    --void:#07070f;
    --panel:#0d0f22;
    --panel-edge:#1b1f45;
    --deep-purple:#241a5e;
    --core-purple:#4b2fd6;
    --cyan:#3ff0e8;
    --cyan-dim:#1c8a86;
    --gold:#f0a830;
    --white:#eef2ff;
    --dim:#7c85b8;
    --danger:#ff4d6d;
    --font-display: 'Orbitron', 'Segoe UI', sans-serif;
    --font-mono: 'Share Tech Mono', 'Consolas', monospace;
  }

  @font-face{
    font-family:'Orbitron';
    src:local('Arial');
  }

  *{ box-sizing:border-box; }

  html,body{
    margin:0; padding:0;
    background:#07070f;
    color:var(--white);
    font-family: var(--font-mono);
    overflow-x:hidden;
  }

  #bglayer{
    position:fixed; inset:-4%;
    background-image:url('data:image/jpeg;base64,');
    background-size:cover;
    background-position:center;
    filter:saturate(1.1) brightness(0.55);
    animation: bgpan 26s ease-in-out infinite alternate;
    z-index:-2;
  }
  #bglayer::after{
    content:"";
    position:absolute; inset:0;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(20,15,50,0.35) 0%, rgba(5,5,12,0.85) 65%, rgba(5,5,12,0.96) 100%);
  }
  @keyframes bgpan{
    0%{ transform:scale(1.04) translate(0,0); }
    100%{ transform:scale(1.1) translate(-1.5%,-1.5%); }
  }

  /* drifting particles */
  #particles{ position:fixed; inset:0; z-index:-1; pointer-events:none; overflow:hidden; }
  #particles span{
    position:absolute; bottom:-5%; width:3px; height:3px; border-radius:50%;
    background:var(--cyan); box-shadow:0 0 6px var(--cyan);
    opacity:0.6; animation-name: drift; animation-timing-function:linear; animation-iteration-count:infinite;
  }
  @keyframes drift{
    0%{ transform:translateY(0) translateX(0); opacity:0; }
    10%{ opacity:0.7; }
    90%{ opacity:0.5; }
    100%{ transform:translateY(-108vh) translateX(30px); opacity:0; }
  }

  #stage{
    position:relative;
    width:100%;
    min-height:100vh;
    padding:22px 22px 40px;
    display:flex;
    flex-direction:column;
    align-items:center;
  }

  /* ambient scan grid */
  #stage::before{
    content:"";
    position:fixed; inset:0;
    background-image:
      linear-gradient(rgba(63,240,232,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(63,240,232,0.035) 1px, transparent 1px);
    background-size: 38px 38px;
    pointer-events:none;
    z-index:0;
  }

  #stage::after{
    content:"";
    position:fixed; left:0; right:0; height:2px;
    background:linear-gradient(90deg, transparent, var(--cyan), transparent);
    opacity:0.35;
    animation: sweep 5.5s linear infinite;
    pointer-events:none;
    z-index:0;
  }

  @keyframes sweep{
    0%{ top:-2%; }
    100%{ top:102%; }
  }

  /* ============ HEADER ============ */
  .hdr{
    width:100%; max-width:1180px;
    display:flex; justify-content:space-between; align-items:flex-end;
    border-bottom:1px solid var(--panel-edge);
    padding-bottom:10px; margin-bottom:16px;
    z-index:1;
    position:relative;
    opacity:0;
    animation: fadeDown .7s ease-out .1s forwards;
  }
  .hdr .brand{
    font-family:var(--font-display);
    font-weight:900;
    letter-spacing:4px;
    font-size:clamp(22px,4vw,34px);
    color:var(--white);
    text-shadow:0 0 14px rgba(63,240,232,0.55);
  }
  .hdr-left{ display:flex; align-items:center; gap:14px; }
  .emblem{
    width:52px; height:58px; object-fit:contain; flex:none;
    filter:drop-shadow(0 0 10px rgba(63,240,232,0.55));
    animation: emblemPulse 3.4s ease-in-out infinite;
  }
  @keyframes emblemPulse{
    0%,100%{ filter:drop-shadow(0 0 8px rgba(63,240,232,0.45)); }
    50%{ filter:drop-shadow(0 0 16px rgba(139,123,255,0.75)); }
  }
  .hdr .brand span{ color:var(--cyan); }
  .hdr .sub{
    font-size:11px; letter-spacing:3px; color:var(--dim); margin-top:4px;
  }
  .hdr .clock{
    text-align:right; font-size:11px; letter-spacing:2px; color:var(--cyan-dim);
  }
  .hdr .clock b{ display:block; color:var(--cyan); font-size:15px; letter-spacing:3px; }

  @keyframes fadeDown{
    from{ opacity:0; transform:translateY(-14px);} to{opacity:1; transform:translateY(0);}
  }

  /* ============ MAIN GRID ============ */
  .wrap{
    width:100%; max-width:1180px;
    display:grid;
    grid-template-columns: 260px 1fr 300px;
    gap:16px;
    z-index:1;
    position:relative;
  }
  @media (max-width:920px){
    .wrap{ grid-template-columns: 1fr; }
  }

  .panel{
    background:linear-gradient(180deg, rgba(27,31,69,0.55), rgba(13,15,34,0.75));
    border:1px solid var(--panel-edge);
    border-radius:6px;
    padding:14px;
    position:relative;
    backdrop-filter: blur(2px);
    opacity:0;
    animation: fadeUp .6s ease-out forwards;
  }
  .panel::before, .panel::after{
    content:""; position:absolute; width:12px; height:12px;
    border:2px solid var(--cyan); opacity:0.8;
  }
  .panel::before{ top:-1px; left:-1px; border-right:none; border-bottom:none; }
  .panel::after{ bottom:-1px; right:-1px; border-left:none; border-top:none; }

  @keyframes fadeUp{
    from{opacity:0; transform:translateY(16px);} to{opacity:1; transform:translateY(0);}
  }

  .label{
    font-size:10px; letter-spacing:3px; color:var(--gold);
    margin-bottom:10px; display:flex; align-items:center; gap:6px;
    font-family:var(--font-display);
  }
  .label::before{
    content:""; width:6px; height:6px; background:var(--gold);
    border-radius:50%; box-shadow:0 0 8px var(--gold);
    animation:blink 1.6s ease-in-out infinite;
  }
  @keyframes blink{ 50%{opacity:.25;} }

  /* ===== LEFT: PILOT ID ===== */
  .left{ animation-delay:.2s; display:flex; flex-direction:column; gap:14px; }

  .idcard{
    border:1px solid var(--panel-edge);
    border-radius:4px;
    background:linear-gradient(160deg, rgba(75,47,214,0.18), rgba(9,9,20,0.4));
    padding:12px;
  }
  .avatar-ring{
    width:88px; height:88px; margin:4px auto 10px;
    border-radius:50%;
    position:relative;
    display:flex; align-items:center; justify-content:center;
  }
  .avatar-ring svg{ position:absolute; inset:0; width:100%; height:100%; animation:spin 9s linear infinite; }
  @keyframes spin{ to{ transform:rotate(360deg);} }
  .avatar-core{
    width:60px; height:60px; border-radius:50%;
    background:radial-gradient(circle at 35% 30%, #8b7bff, var(--core-purple) 55%, #1a1140 100%);
    box-shadow:0 0 22px rgba(75,47,214,0.85), inset 0 0 10px rgba(0,0,0,0.5);
    display:flex; align-items:center; justify-content:center;
    font-family:var(--font-display); font-weight:900; color:var(--white);
    font-size:22px; letter-spacing:1px;
  }

  .idname{ text-align:center; font-family:var(--font-display); font-weight:700; letter-spacing:1px; font-size:16px; color:var(--white); }
  .idrole{ text-align:center; font-size:10.5px; letter-spacing:2px; color:var(--cyan); margin-top:2px; margin-bottom:10px;}

  .idrow{
    display:flex; justify-content:space-between;
    font-size:11px; padding:5px 0;
    border-top:1px dashed rgba(124,133,184,0.25);
    color:var(--dim); letter-spacing:1px;
  }
  .idrow b{ color:var(--white); font-weight:400; }
  .idrow .ok{ color:var(--cyan); }

  .barcode{
    margin-top:10px; height:26px; border-radius:2px;
    background:repeating-linear-gradient(90deg, var(--white) 0 2px, transparent 2px 5px, var(--cyan) 5px 6px, transparent 6px 9px);
    opacity:0.75;
  }
  .idnum{ text-align:center; font-size:10px; letter-spacing:3px; color:var(--dim); margin-top:5px; }

  .statusbar{ margin-top:2px; }
  .statusbar .row{ display:flex; justify-content:space-between; font-size:10px; color:var(--dim); margin-bottom:3px; letter-spacing:1px;}
  .bartrack{ height:6px; border-radius:3px; background:rgba(124,133,184,0.15); overflow:hidden; margin-bottom:10px; }
  .barfill{ height:100%; border-radius:3px; background:linear-gradient(90deg, var(--cyan-dim), var(--cyan)); box-shadow:0 0 8px var(--cyan);
    animation: fillIn 1.4s ease-out forwards; transform-origin:left; }
  @keyframes fillIn{ from{ transform:scaleX(0);} to{ transform:scaleX(1);} }

  /* ===== CENTER: ROBOT DISPLAY ===== */
  .center{ animation-delay:.15s; display:flex; flex-direction:column; align-items:center; padding:16px 12px; }
  .designation{
    font-family:var(--font-display); font-weight:900; letter-spacing:5px;
    font-size:clamp(20px,3vw,28px); color:var(--white); text-align:center;
    text-shadow:0 0 16px rgba(63,240,232,0.6);
  }
  .designation span{ color:var(--gold); }
  .classline{ font-size:10.5px; letter-spacing:3px; color:var(--dim); margin-top:4px; margin-bottom:14px; text-align:center;}

  .frame{
    position:relative;
    width:min(340px, 78vw);
    border:1px solid var(--panel-edge);
    border-radius:4px;
    overflow:hidden;
    background:#05050c;
  }
  .frame img{ display:block; width:100%; height:auto; filter:saturate(1.08) contrast(1.03); }

  .frame .reticle{
    position:absolute; inset:0; pointer-events:none;
  }
  .frame .corner{
    position:absolute; width:26px; height:26px; border:2px solid var(--cyan);
    opacity:0.9; filter:drop-shadow(0 0 4px var(--cyan));
  }
  .frame .corner.tl{ top:8px; left:8px; border-right:none; border-bottom:none; }
  .frame .corner.tr{ top:8px; right:8px; border-left:none; border-bottom:none; }
  .frame .corner.bl{ bottom:8px; left:8px; border-right:none; border-top:none; }
  .frame .corner.br{ bottom:8px; right:8px; border-left:none; border-top:none; }

  .frame .scanline{
    position:absolute; left:0; right:0; height:2px;
    background:linear-gradient(90deg, transparent, var(--cyan), transparent);
    box-shadow:0 0 10px var(--cyan);
    animation: scan 3.4s ease-in-out infinite;
  }
  @keyframes scan{
    0%,100%{ top:6%; opacity:0;}
    10%{opacity:1;}
    50%{ top:92%; opacity:1;}
    60%{opacity:0;}
  }

  .frame .lockring{ display:none; }

  .tagrow{
    display:flex; gap:10px; margin-top:14px; flex-wrap:wrap; justify-content:center;
  }
  .tag{
    font-size:10px; letter-spacing:2px; padding:5px 10px; border:1px solid var(--panel-edge);
    border-radius:20px; color:var(--cyan); background:rgba(63,240,232,0.06);
  }

  /* ===== MIND CORE MINI PANEL ===== */
  .mindcore{
    margin-top:16px; width:100%; max-width:340px;
    border:1px solid var(--panel-edge); border-radius:6px;
    padding:12px; background:radial-gradient(ellipse at 50% 0%, rgba(75,47,214,0.16), rgba(9,9,20,0.5));
    display:flex; align-items:center; gap:12px;
  }
  .core-orb{
    width:52px; height:52px; flex:none; border-radius:50%; position:relative;
    background:radial-gradient(circle at 35% 30%, #b7a8ff, var(--core-purple) 55%, #150c3d 100%);
    box-shadow:0 0 24px rgba(107,79,230,0.8);
    animation: pulseCore 2.1s ease-in-out infinite;
  }
  @keyframes pulseCore{
    0%,100%{ box-shadow:0 0 16px rgba(107,79,230,0.65); transform:scale(1); }
    50%{ box-shadow:0 0 30px rgba(160,140,255,0.95); transform:scale(1.06); }
  }
  .core-orb::after{
    content:""; position:absolute; inset:-6px; border:1px solid rgba(160,140,255,0.4); border-radius:50%;
    animation:pulseCore 2.1s ease-in-out infinite reverse;
  }
  .core-info{ flex:1; }
  .core-info .t{ font-family:var(--font-display); font-size:12px; letter-spacing:2px; color:var(--white); margin-bottom:4px;}
  .core-info .s{ font-size:10px; letter-spacing:1.5px; color:var(--cyan); margin-bottom:6px;}
  .core-info .meter{ height:5px; border-radius:3px; background:rgba(124,133,184,0.18); overflow:hidden; }
  .core-info .meter i{ display:block; height:100%; width:91%; background:linear-gradient(90deg,#6b4fe6,#b7a8ff); box-shadow:0 0 6px #8b7bff; }

  /* ===== RIGHT: POWERS ===== */
  .right{ animation-delay:.25s; }
  .power{
    margin-bottom:12px; padding-bottom:10px; border-bottom:1px dashed rgba(124,133,184,0.2);
  }
  .power:last-child{ border-bottom:none; margin-bottom:0; }
  .power .pname{
    display:flex; justify-content:space-between; align-items:center;
    font-size:12px; letter-spacing:1px; color:var(--white); margin-bottom:5px;
    font-family:var(--font-display);
  }
  .power .pname .ico{ color:var(--gold); margin-right:6px; }
  .power .pdesc{ font-size:10.5px; color:var(--dim); line-height:1.5; margin-bottom:6px; }
  .power .meter{ height:5px; border-radius:3px; background:rgba(124,133,184,0.15); overflow:hidden; }
  .power .meter i{
    display:block; height:100%; background:linear-gradient(90deg, var(--cyan-dim), var(--cyan));
    box-shadow:0 0 6px var(--cyan);
    animation: fillIn 1.3s ease-out forwards; transform-origin:left;
  }

  /* ===== MIND CORE DIAGNOSTIC PANEL ===== */
  .corepanel{
    width:100%; max-width:1180px; margin-top:16px;
    z-index:1; position:relative;
  }

  .core-topbar, .core-bottombar{
    display:flex; align-items:center; gap:8px; margin:4px 0 14px;
  }
  .core-bottombar{ margin:14px 0 2px; justify-content:flex-end; }
  .core-topbar .dot, .core-bottombar .dot{
    width:9px; height:9px; border-radius:50%; background:var(--cyan);
    box-shadow:0 0 8px var(--cyan); flex:none;
    animation:blink 1.6s ease-in-out infinite;
  }
  .core-topbar .seg, .core-bottombar .seg{
    height:5px; border-radius:3px;
    background:linear-gradient(90deg, rgba(63,240,232,0.15), rgba(63,240,232,0.55), rgba(63,240,232,0.15));
    position:relative; overflow:hidden;
  }
  .core-topbar .seg-a{ width:22%; }
  .core-topbar .seg-b{ flex:1; }
  .core-bottombar .seg-a{ width:22%; }
  .core-bottombar .seg-b{ flex:1; }
  .core-topbar .seg::after, .core-bottombar .seg::after{
    content:""; position:absolute; top:0; bottom:0; width:24px;
    background:linear-gradient(90deg, transparent, #fff, transparent);
    opacity:.6; animation: segrun 3.2s linear infinite;
  }
  @keyframes segrun{ from{ left:-10%;} to{ left:110%;} }

  .core-body{
    display:grid;
    grid-template-columns: 1fr 1.3fr 1fr;
    gap:18px;
    align-items:center;
  }
  @media (max-width:820px){
    .core-body{ grid-template-columns: 1fr; }
  }

  .core-col{ display:flex; flex-direction:column; gap:12px; }

  .code-readout{
    background:rgba(6,6,16,0.6); border:1px solid var(--panel-edge); border-radius:6px;
    padding:8px 10px; font-size:10px; line-height:1.7; color:var(--cyan-dim);
    height:96px; overflow:hidden; white-space:pre; letter-spacing:0.5px;
    box-shadow:inset 0 1px 0 rgba(255,255,255,0.06), inset 0 -2px 6px rgba(0,0,0,0.6), 0 6px 16px rgba(0,0,0,0.45);
  }
  .code-readout .l{ display:block; }
  .code-readout .l .num{ color:var(--gold); margin-right:6px; }
  .code-readout .cursor{ display:inline-block; width:6px; height:11px; background:var(--cyan); vertical-align:middle; animation:blink .9s steps(2) infinite; }

  .mini-box{
    background:linear-gradient(180deg, rgba(27,25,55,0.55), rgba(6,6,16,0.6));
    border:1px solid var(--panel-edge); border-radius:6px; padding:8px 10px;
    box-shadow:inset 0 1px 0 rgba(255,255,255,0.06), inset 0 -2px 6px rgba(0,0,0,0.6), 0 6px 16px rgba(0,0,0,0.45);
  }
  .mini-title{ font-size:9px; letter-spacing:2px; color:var(--dim); margin-bottom:6px; }
  .barchart, .wavechart{ width:100%; height:auto; display:block; }

  .core-center-col{ align-items:center; }
  .orb-stage{
    position:relative; width:190px; height:190px;
    display:flex; align-items:center; justify-content:center;
    perspective:700px;
  }
  .orb-ring{
    position:absolute; border-radius:50%; border:1px solid rgba(139,123,255,0.35);
  }
  .orb-ring.r1{ inset:-6px; animation: spin 14s linear infinite; border-style:dashed; }
  .orb-ring.r2{ inset:-18px; animation: spin 22s linear infinite reverse; border-color:rgba(63,240,232,0.25); }
  .orb-svg{
    width:100%; height:100%;
    transform-style:preserve-3d;
    animation: orbTilt 7s ease-in-out infinite, orbPulse 2.2s ease-in-out infinite;
  }
  @keyframes orbTilt{
    0%{ transform:rotateY(-18deg) rotateX(9deg) rotateZ(0deg); }
    50%{ transform:rotateY(18deg) rotateX(-7deg) rotateZ(4deg); }
    100%{ transform:rotateY(-18deg) rotateX(9deg) rotateZ(0deg); }
  }
  @keyframes orbPulse{ 0%,100%{ filter:brightness(1) saturate(1);} 50%{ filter:brightness(1.22) saturate(1.25);} }

  .cracklines path{
    animation: crackColor 2.8s ease-in-out infinite;
  }
  .cracklines path:nth-child(2n){ animation-delay:.5s; }
  .cracklines path:nth-child(3n){ animation-delay:1s; }
  @keyframes crackColor{
    0%, 100%{ stroke:#8ff7f2; opacity:.55; }
    35%{ stroke:#3ff0e8; opacity:1; }
    70%{ stroke:#f0c060; opacity:.8; }
  }

  .spark{ animation: sparkFlicker 1.4s ease-in-out infinite; }
  @keyframes sparkFlicker{ 0%,100%{ opacity:.15; r:1.4;} 50%{ opacity:1; r:2.6;} }

  .plasma-haze{
    animation: plasmaShift 5s ease-in-out infinite alternate;
    mix-blend-mode:screen;
  }
  @keyframes plasmaShift{
    0%{ filter:hue-rotate(0deg) blur(2px); opacity:.55; }
    50%{ filter:hue-rotate(35deg) blur(1px); opacity:.8; }
    100%{ filter:hue-rotate(-20deg) blur(2px); opacity:.55; }
  }

  .orb-caption{
    position:absolute; bottom:-6px; font-size:9px; letter-spacing:2px; color:var(--cyan);
    background:rgba(6,6,16,0.75); padding:2px 8px; border-radius:10px; border:1px solid var(--panel-edge);
  }
  .core-readout-number{
    margin-top:14px; font-size:13px; letter-spacing:2px; color:var(--cyan);
    text-shadow:0 0 8px rgba(63,240,232,0.6);
  }

  .tech-panel{
    background:linear-gradient(180deg, rgba(27,25,55,0.55), rgba(6,6,16,0.6));
    border:1px solid var(--panel-edge); border-radius:6px; padding:10px;
    box-shadow:inset 0 1px 0 rgba(255,255,255,0.06), inset 0 -2px 6px rgba(0,0,0,0.6), 0 6px 16px rgba(0,0,0,0.45);
  }
  .tech-row{ height:6px; border-radius:3px; background:rgba(63,240,232,0.18); margin-bottom:6px; }
  .tech-row.short{ width:55%; background:rgba(240,168,48,0.35); }
  .tech-grid{
    display:grid; grid-template-columns:repeat(4,1fr); gap:5px; margin-top:8px;
  }
  .tech-grid div{
    height:20px; border:1px solid rgba(124,133,184,0.3); border-radius:3px;
    background:rgba(75,47,214,0.12);
    box-shadow:inset 0 1px 0 rgba(255,255,255,0.08), inset 0 -2px 4px rgba(0,0,0,0.5);
  }
  .tech-grid div:nth-child(3n){ background:rgba(63,240,232,0.1); }

  .core-caption{
    text-align:center; font-size:11px; letter-spacing:1px; color:var(--white);
    background:rgba(6,6,16,0.6); border:1px solid var(--panel-edge); border-radius:4px;
    padding:8px; margin-top:8px;
  }

  /* footer */
  .ftr{
    max-width:1180px; width:100%; margin-top:18px; text-align:center;
    font-size:10px; letter-spacing:3px; color:var(--dim); z-index:1; position:relative;
  }
  .ftr b{ color:var(--cyan); }
</style>
</head>
<body>
<div id="bglayer"></div>
<div id="particles"></div>
<div id="stage">

  <div class="hdr">
    <div class="hdr-left">
      <img class="emblem" src="data:image/jpeg;base64," alt="G-Force emblem">
      <div>
        <div class="brand">TOBOT <span>G&#8209;FORCE</span></div>
        <div class="sub">DAEDO CITY DEFENSE NETWORK &mdash; PILOT INTERFACE</div>
      </div>
    </div>
    <div class="clock">
      <b id="clockval">00:00:00</b>
      LINK STATUS: <span style="color:var(--cyan)">ONLINE</span>
    </div>
  </div>

  <div class="wrap">

    <!-- LEFT: PILOT ID -->
    <div class="panel left">
      <div class="label">PILOT IDENTIFICATION</div>
      <div class="idcard">
        <div class="avatar-ring">
          <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="46" fill="none" stroke="#3ff0e8" stroke-width="1.5" stroke-dasharray="6 10" opacity="0.7"/></svg>
          <div class="avatar-core">GL</div>
        </div>
        <div class="idname">GARRETT LAMPI</div>
        <div class="idrole">TOBOT G-FORCE &middot; PRIMARY PILOT</div>

