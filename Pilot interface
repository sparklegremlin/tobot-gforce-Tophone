<script>
  function tick(){
    const d = new Date();
    const s = d.toLocaleTimeString('en-US',{hour12:false});
    document.getElementById('clockval').textContent = s;
  }
  // ---- drifting background particles ----
  const pField = document.getElementById('particles');
  const colors = ['var(--cyan)','#8b7bff','var(--gold)'];
  for(let i=0;i<26;i++){
    const s = document.createElement('span');
    const left = Math.random()*100;
    const dur = 10 + Math.random()*14;
    const delay = Math.random()*-20;
    const size = 2 + Math.random()*2.5;
    const c = colors[Math.floor(Math.random()*colors.length)];
    s.style.left = left+'vw';
    s.style.width = size+'px';
    s.style.height = size+'px';
    s.style.background = c;
    s.style.boxShadow = '0 0 6px '+c;
    s.style.animationDuration = dur+'s';
    s.style.animationDelay = delay+'s';
    pField.appendChild(s);
  }

  tick();
  setInterval(tick,1000);

  // ---- Mind Core code readout ----
  const codeLines = [
    "SYS.CORE >> resonance.lock(GL_07)",
    "buffer.sync :: 96.2%",
    "fold.matrix[W] -> stable",
    "aux.channel :: nominal",
    "pilot.bond :: LOCKED",
    "output.clamp :: 91.4%",
    "thermal.core :: 41.2C",
    "field.integrity :: 99%"
  ];
  const readoutEl = document.getElementById('codeReadout');
  function renderCode(){
    readoutEl.innerHTML = codeLines.map((l,i)=>{
      const n = String(i+1).padStart(2,'0');
      return '<span class="l"><span class="num">'+n+'</span>'+l+'</span>';
    }).join('') + '<span class="cursor"></span>';
  }
  renderCode();

  // ---- fluctuating core number ----
  const numEl = document.getElementById('coreNumber');
  let base = 125512.65664527;
  setInterval(()=>{
    const jitter = (Math.random()-0.5)*0.4;
    numEl.textContent = (base + jitter).toFixed(8);
  }, 900);

  // ---- fluctuating waveform (cyan main, purple + gold echoes) ----
  const waveCyan = document.querySelector('.wave-cyan');
  const wavePurple = document.querySelector('.wave-purple');
  const waveGold = document.querySelector('.wave-gold');
  let t0 = 0;
  function randomWave(){
    t0 += 0.6;
    const cyanPts=[], purplePts=[], goldPts=[];
    for(let x=0; x<=200; x+=15){
      const yc = 26 + Math.sin(x/18 + t0) * 14 + (Math.random()-0.5)*5;
      const yp = 30 + Math.sin(x/12 + t0*1.4 + 1.2) * 16;
      const yg = 32 + Math.sin(x/22 + t0*0.7 + 2.4) * 10;
      cyanPts.push(x+','+Math.max(4,Math.min(56,yc)).toFixed(1));
      purplePts.push(x+','+Math.max(4,Math.min(56,yp)).toFixed(1));
      goldPts.push(x+','+Math.max(4,Math.min(56,yg)).toFixed(1));
    }
    waveCyan.setAttribute('points', cyanPts.join(' '));
    wavePurple.setAttribute('points', purplePts.join(' '));
    waveGold.setAttribute('points', goldPts.join(' '));
  }
  setInterval(randomWave, 700);

  // ---- shifting bar chart ----
  const bars = document.querySelectorAll('.barchart rect');
  setInterval(()=>{
    bars.forEach(b=>{
      const h = 10 + Math.random()*46;
      b.setAttribute('height', h.toFixed(1));
      b.setAttribute('y', (60-h).toFixed(1));
    });
  }, 1600);
</script>
